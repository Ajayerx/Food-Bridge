<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Base config: trust system + user certificates for ALL domains.
        Without this, Android 7+ (API 24) restricts user CAs to only
        explicitly-listed domains.  This is needed for:
          - Debugging with proxy tools (Charles, mitmproxy) that install
            a user CA certificate
          - Tile CDNs that present certificates chaining to less-common
            CAs not shipped in every device's system trust store
    -->
    <base-config>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!--
        Allow cleartext only for local dev (Metro bundler).
        All map tile domains use HTTPS — they don't need cleartext.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
    </domain-config>

</network-security-config>
